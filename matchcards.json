<script>
function triggerLandscapeView(id) {
    var el = document.getElementById(id);
    if (el.requestFullscreen) { el.requestFullscreen().then(() => { lockScreen(); }); }
    else if (el.webkitRequestFullscreen) { el.webkitRequestFullscreen().then(() => { lockScreen(); }); }
    else if (el.mozRequestFullScreen) { el.mozRequestFullScreen().then(() => { lockScreen(); }); }
}
function lockScreen() {
    if (screen.orientation && screen.orientation.lock) {
        screen.orientation.lock('landscape').catch(e => console.log(e));
    }
}
</script>




